<mxfile host="app.diagrams.net">
  <diagram name="Hình 3.3 - Agent loop" id="agent-loop-diagram">
    <mxGraphModel dx="896" dy="489" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="1050" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;align=center;fontSize=15;fontStyle=1;" value="Hình 3.3. Vòng lặp suy luận của AI Agent (4 pha)" vertex="1">
          <mxGeometry height="30" width="440" x="230" y="20" as="geometry" />
        </mxCell>
        <mxCell id="start" parent="1" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="Start&lt;br&gt;(receive ContextBundle)" vertex="1">
          <mxGeometry height="50" width="200" x="340" y="70" as="geometry" />
        </mxCell>
        <mxCell id="ph1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="&lt;b&gt;Phase 1 — Assemble Context&lt;/b&gt;&lt;br&gt;system prompt + bundle + output schema" vertex="1">
          <mxGeometry height="60" width="280" x="300" y="150" as="geometry" />
        </mxCell>
        <mxCell id="ph2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="&lt;b&gt;Phase 2 — Call LLM&lt;/b&gt;" vertex="1">
          <mxGeometry height="50" width="280" x="300" y="250" as="geometry" />
        </mxCell>
        <mxCell id="dtool" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="Tool call&lt;br&gt;requested?" vertex="1">
          <mxGeometry height="90" width="160" x="360" y="340" as="geometry" />
        </mxCell>
        <mxCell id="ph3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" value="&lt;b&gt;Phase 3 — Execute Tools&lt;/b&gt;&lt;br&gt;(read-only: logs, metrics, alerts,&lt;br&gt;dependencies, inspect...)" vertex="1">
          <mxGeometry height="80" width="260" x="660" y="345" as="geometry" />
        </mxCell>
        <mxCell id="ph4" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" value="&lt;b&gt;Phase 4 — Feed Results Back&lt;/b&gt;&lt;br&gt;(update conversation history)" vertex="1">
          <mxGeometry height="60" width="240" x="670" y="470" as="geometry" />
        </mxCell>
        <mxCell id="dturn" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="turn &amp;lt; 8?" vertex="1">
          <mxGeometry height="90" width="160" x="710" y="580" as="geometry" />
        </mxCell>
        <mxCell id="force" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="Force Final Answer&lt;br&gt;(from evidence gathered)" vertex="1">
          <mxGeometry height="50" width="220" x="680" y="715" as="geometry" />
        </mxCell>
        <mxCell id="parse" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" value="&lt;b&gt;Parse JSON&lt;/b&gt;&lt;br&gt;→ List&amp;lt;IncidentReport&amp;gt;" vertex="1">
          <mxGeometry height="60" width="240" x="320" y="480" as="geometry" />
        </mxCell>
        <mxCell id="end" parent="1" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="End&lt;br&gt;(return incident reports)" vertex="1">
          <mxGeometry height="50" width="200" x="340" y="665" as="geometry" />
        </mxCell>
        <mxCell id="l0" edge="1" parent="1" source="start" style="endArrow=classic;html=1;" target="ph1">
