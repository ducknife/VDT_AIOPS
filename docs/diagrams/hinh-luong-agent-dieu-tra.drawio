        <mxCell id="p3" value="Pha 3 · Thực thi công cụ&lt;br&gt;ToolCallingManager" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F9A825;fontSize=12;fontFamily=Verdana;" vertex="1" parent="1">
