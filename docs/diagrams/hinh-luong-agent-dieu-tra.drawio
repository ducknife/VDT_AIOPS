<mxfile host="app.diagrams.net" version="24.0.0">
  <diagram name="Luong AI Agent dieu tra" id="agent-flow">
    <mxGraphModel dx="900" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="840" pageHeight="720" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Luồng điều tra của AI Agent (vòng lặp agentic 4 pha)" style="text;html=1;fontStyle=1;fontSize=15;align=center;fontFamily=Verdana;" vertex="1" parent="1">
          <mxGeometry x="120" y="14" width="560" height="30" as="geometry" />
        </mxCell>

        <mxCell id="start" value="Nhận ContextBundle&lt;br&gt;&lt;i&gt;bắt đầu điều tra&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=13;fontStyle=1;fontFamily=Verdana;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="180" y="62" width="300" height="56" as="geometry" />
        </mxCell>

        <mxCell id="p1" value="Pha 1 · Lắp ráp ngữ cảnh&lt;br&gt;system prompt + gói ngữ cảnh + lược đồ output" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF2FB;strokeColor=#1565C0;fontSize=12;fontFamily=Verdana;" vertex="1" parent="1">
