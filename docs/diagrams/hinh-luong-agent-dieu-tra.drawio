        <mxCell id="ed" value="CÓ · turn &lt; MAX_TURNS" style="endArrow=block;html=1;strokeColor=#F9A825;strokeWidth=2;fontColor=#B26A00;fontSize=10;fontFamily=Verdana;" edge="1" parent="1" source="dia" target="p3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ee" style="endArrow=block;html=1;strokeColor=#F9A825;strokeWidth=2;fontFamily=Verdana;" edge="1" parent="1" source="p3" target="p4"><mxGeometry relative="1" as="geometry" /></mxCell>
