        <mxCell id="parse" value="Bóc tách JSON + ràng buộc lược đồ&lt;br&gt;JsonExtractor · BeanOutputConverter" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF2FB;strokeColor=#1565C0;fontSize=12;fontFamily=Verdana;" vertex="1" parent="1">
          <mxGeometry x="180" y="474" width="300" height="56" as="geometry" />
        </mxCell>

        <mxCell id="end" value="IncidentReport&lt;br&gt;&lt;i&gt;chẩn đoán có cấu trúc: severity · root cause · findings · actions&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=13;fontStyle=1;fontFamily=Verdana;shadow=1;" vertex="1" parent="1">
