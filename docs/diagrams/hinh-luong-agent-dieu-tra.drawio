        <mxCell id="p2" value="Pha 2 · Gọi mô hình (ChatModel)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0B2E6B;fontColor=#FFFFFF;strokeColor=#0B2E6B;fontSize=13;fontFamily=Verdana;" vertex="1" parent="1">
          <mxGeometry x="200" y="244" width="260" height="48" as="geometry" />
        </mxCell>

        <mxCell id="dia" value="Mô hình còn&lt;br&gt;yêu cầu công cụ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F9A825;fontSize=12;fontFamily=Verdana;" vertex="1" parent="1">
          <mxGeometry x="250" y="322" width="160" height="96" as="geometry" />
