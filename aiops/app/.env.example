# Copy this file to `.env` and fill in real values. The real `.env` is gitignored.
# Spring Boot does NOT read .env automatically - load it via one of:
#   - PowerShell:  $env:ANTHROPIC_API_KEY = "..."   (same terminal as mvnw)
#   - System environment variable (persistent)
#   - application.yaml:  spring.config.import: optional:file:.env[.properties]

ANTHROPIC_API_KEY=sk-ant-your-key-here
