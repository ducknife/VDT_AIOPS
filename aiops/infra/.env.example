# =============================================================================
# Copy file này thành .env rồi điền giá trị THẬT.
# KHÔNG điền secret thật vào file .example này (nó được commit lên git).
# docker compose tự nạp .env (cùng thư mục) để thay ${VAR} trong compose.
# =============================================================================

# ── Simulation app DB (postgres) ──
APP_DB_PASSWORD=apppassword

# ── AIOps state DB (postgres-aiops) + engine ──
AIOPS_DB_PASSWORD=change_me

# ── Claude (Anthropic) ──
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ── Redis maxmemory (mô phỏng OOM) ──
REDIS_MAX_MEMORY=256mb
