# Copy file này thành .env và điền giá trị thực
# docker compose tự load file .env trong cùng thư mục

POSTGRES_PASSWORD=apppassword
REDIS_MAX_MEMORY=256mb

# Docker host — mặc định tcp://localhost:2375 (bật TCP trong Docker Desktop Settings > General)
# Linux / Mac: unix:///var/run/docker.sock
# DOCKER_HOST=tcp://localhost:2375
